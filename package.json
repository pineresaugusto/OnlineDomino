{
  "name": "onlinedomino",
  "version": "0.0.0",
  "private": true,
  "packageManager": "pnpm@11.9.0",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "pnpm --filter @domino/shared build && pnpm -r --parallel dev",
    "dev:web": "pnpm --filter @domino/shared build && pnpm --filter @domino/web dev",
    "dev:server": "pnpm --filter @domino/shared build && pnpm --filter @domino/server dev",
    "build": "pnpm -r build",
    "test": "pnpm -r test",
    "lint": "pnpm -r lint"
  },
  "devDependencies": {
    "typescript": "^5.7.0"
  }
}
